{
  "apis": {
    "agora": {
      "base_url": "https://core.agoraai.tech",
      "spec_files": [
        "openapi/agora-public-api.yaml"
      ],
      "profiles": {
        "default": {
          "credentials": {
            "bearerAuth": {
              "auth": {
                "type": "bearer",
                "params": {
                  "token": "env:AGORA_ACCESS_TOKEN"
                }
              }
            }
          }
        },
        "dev": {
          "credentials": {
            "bearerAuth": {
              "auth": {
                "type": "bearer",
                "params": {
                  "token": "env:AGORA_ACCESS_TOKEN"
                }
              }
            }
          },
          "base_url": "https://core-dev.agoraai.tech"
        }
      }
    }
  }
}
