{
  "apis": {
    "agora": {
      "base_url": "https://core.agoraai.tech",
      "spec_files": [
        "openapi/agora-public-api.yaml"
      ],
      "profiles": {
        "default": {
          "credentials": {
            "bearerAuth": {
              "auth": {
                "type": "external-tool",
                "params": {
                  "commandline": "bash scripts/get-token.sh https://core.agoraai.tech"
                }
              }
            }
          }
        },
        "dev": {
          "base_url": "https://core-dev.agoraai.tech",
          "credentials": {
            "bearerAuth": {
              "auth": {
                "type": "external-tool",
                "params": {
                  "commandline": "bash scripts/get-token.sh https://core-dev.agoraai.tech"
                }
              }
            }
          }
        }
      }
    }
  }
}
